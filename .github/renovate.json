{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>iddqd-uk/.github//renovate/default",
    ":rebaseStalePrs"
  ],
  "schedule": ["monthly"],
  "enabledManagers": [
    "helm-values",
    "helmv3",
    "custom.regex"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["video-dl-bot"],
      "minimumReleaseAge": "0 days",
      "prNotPendingHours": 0,
      "schedule": ["at any time"]
    }
  ]
}
